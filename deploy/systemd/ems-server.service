[Unit]
Description=EMS Forecast Server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=__USER__
WorkingDirectory=__WORKDIR__
EnvironmentFile=__WORKDIR__/.env
Environment=DATA_DIR=/var/lib/ems-server
StateDirectory=ems-server
ExecStart=__WORKDIR__/scripts/start.sh
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
