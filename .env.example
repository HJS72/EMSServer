# Service
HOST=0.0.0.0
PORT=8080
TZ=Europe/Berlin
DATA_DIR=./data

# InfluxDB source (ioBroker Influx adapter target or native InfluxDB)
INFLUX_URL=http://127.0.0.1:8086
INFLUX_TOKEN=change-me
INFLUX_ORG=ems
INFLUX_BUCKET=iobroker
INFLUX_MEASUREMENT=iobroker
# If your ioBroker adapter stores state IDs as measurements, leave INFLUX_TAG_KEY empty.
# Then STATE_* keys are matched directly to _measurement.
INFLUX_TAG_KEY=id
INFLUX_VALUE_FIELD=value

# Optional raw Flux overrides for special schemas
INFLUX_CONSUMPTION_QUERY=
INFLUX_PV_QUERY=
INFLUX_GRID_IMPORT_QUERY=
INFLUX_GRID_EXPORT_QUERY=

# ioBroker direct fallback (simple-api)
IOBROKER_URL=http://127.0.0.1:8087
IOBROKER_USERNAME=
IOBROKER_PASSWORD=

# PV internet forecast
PV_FORECAST_PROVIDER=forecast_solar
PV_FORECAST_LAT=48.137
PV_FORECAST_LON=11.575
PV_FORECAST_KWP=10.0
PV_FORECAST_AZIMUTH=180
PV_FORECAST_DECLINATION=35

# State keys
STATE_CONSUMPTION_KEY=house.power.consumption
STATE_PV_KEY=house.power.pv
STATE_GRID_IMPORT_KEY=EMS.Grid.Energie.in
STATE_GRID_EXPORT_KEY=EMS.Grid.Energie.out

# Forecast settings
FORECAST_HOURS=24
HISTORY_DAYS=30

# OTA update from GitHub
GITHUB_REPO_URL=https://github.com/your-org/EMSServer.git
GITHUB_BRANCH=main
SERVICE_NAME=ems-server
